## 6. Agent Orchestration Loop

```python
import anthropic
import json

client = anthropic.Anthropic()

SYSTEM_PROMPT = """You are a protein engineering agent. Given a protein engineering task,
you orchestrate computational biology tools to evaluate candidate sequences and return
scientifically justified rankings.

For each task you must:
1. Parse the goal: identify target protein, desired property, constraints
2. For each candidate sequence, call tools in this order:
   a. score_sequence_esm2 (sequence fitness)
   b. predict_structure_esmfold (structural confidence)
   c. compute_structural_similarity (fold retention vs. reference)
   d. blast_conservation (evolutionary support at mutated positions)
3. Call rank_candidates with aggregated evidence
4. Return a structured summary with top candidates and per-factor justification

Always call tools before drawing conclusions. Never hallucinate scores.
If a tool fails, note the failure in your reasoning and proceed without that signal."""

def run_agent(task: str, sequences: dict[str, str], wildtype: str,
              reference_pdb_path: str, stream_callback=None) -> dict:
    """
    Main agent loop. Runs until no more tool_use blocks returned.
    stream_callback: optional function called with each reasoning step string.
    """
    messages = [{"role": "user", "content": f"Task: {task}\n\nWildtype: {wildtype}\n\n"
                                             f"Candidates: {json.dumps(sequences)}"}]

    tool_implementations = {
        "score_sequence_esm2": score_sequence_esm2,
        "predict_structure_esmfold": predict_structure_esmfold,
        "compute_structural_similarity": compute_structural_similarity,
        "blast_conservation": blast_conservation,
        "rank_candidates": rank_candidates,
    }

    while True:
        response = client.messages.create(
            model="claude-sonnet-4-5-20251022",
            max_tokens=4096,
            system=SYSTEM_PROMPT,
            tools=tools,
            messages=messages
        )

        # Stream any text blocks
        for block in response.content:
            if block.type == "text" and stream_callback:
                stream_callback({"type": "reasoning", "text": block.text})

        # If no tool use, agent is done
        if response.stop_reason == "end_turn":
            final_text = next((b.text for b in response.content if b.type == "text"), "")
            return {"status": "complete", "summary": final_text}

        # Execute all tool calls
        tool_results = []
        for block in response.content:
            if block.type != "tool_use":
                continue

            if stream_callback:
                stream_callback({"type": "tool_call", "tool": block.name,
                                 "input": block.input})
            try:
                result = tool_implementations[block.name](**block.input)
                tool_results.append({
                    "type": "tool_result",
                    "tool_use_id": block.id,
                    "content": json.dumps(result)
                })
                if stream_callback:
                    stream_callback({"type": "tool_result", "tool": block.name,
                                     "result": result})
            except Exception as e:
                tool_results.append({
                    "type": "tool_result",
                    "tool_use_id": block.id,
                    "content": f"Error: {str(e)}",
                    "is_error": True
                })

        # Append assistant turn + tool results
        messages.append({"role": "assistant", "content": response.content})
        messages.append({"role": "user", "content": tool_results})
```

